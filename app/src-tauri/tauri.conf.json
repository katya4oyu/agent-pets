{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "navi",
  "version": "0.1.0",
  "identifier": "com.katya4oyu.navi",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "navi",
        "width": 320,
        "height": 260,
        "minWidth": 320,
        "minHeight": 220,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
