{
  "name": "agent-pets",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.0.3",
  "scripts": {
    "dev": "pnpm --dir app dev",
    "build": "pnpm --dir app build",
    "build:playground": "pnpm --dir app build:playground",
    "preview": "pnpm --dir app preview",
    "preview:playground": "pnpm --dir app preview:playground",
    "tauri": "pnpm --dir app tauri",
    "tauri:dev": "pnpm --dir app tauri dev",
    "test": "pnpm --dir app test",
    "check:rust": "cargo check --manifest-path app/src-tauri/Cargo.toml"
  }
}
